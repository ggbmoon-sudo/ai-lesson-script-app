AI_PROVIDER=openai-compatible
OPENAI_COMPAT_BASE_URL=https://api.newcoin.top
# Optional: set only if your provider gives a full chat completions URL.
OPENAI_COMPAT_CHAT_URL=
OPENAI_COMPAT_API_KEY=your_newcoin_api_key_here
OPENAI_COMPAT_MODEL=qwen3.6-plus
OPENAI_COMPAT_TEMPERATURE=0.25
OPENAI_COMPAT_MAX_TOKENS=16384
OPENAI_COMPAT_SCRIPT_MAX_TOKENS=32768
OPENAI_COMPAT_DISABLE_THINKING=true
# Optional raw JSON object merged into OpenAI-compatible chat requests.
OPENAI_COMPAT_EXTRA_BODY=

# Optional Gemini fallback if you later switch AI_PROVIDER=gemini.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-pro-preview
GEMINI_THINKING_LEVEL=high
GEMINI_THINKING_BUDGET=-1
GEMINI_TEMPERATURE=0.25
GEMINI_MAX_OUTPUT_TOKENS=32768
GEMINI_SCRIPT_MAX_OUTPUT_TOKENS=32768

GOOGLE_DRIVE_CLIENT_ID=your_google_drive_oauth_client_id_here
GAMMA_API_KEY=your_gamma_api_key_here
GAMMA_EXPORT_AS=pptx
GAMMA_TEXT_MODE=generate
GAMMA_THEME_ID=
GAMMA_FOLDER_IDS=
PORT=4173
